# Database
DATABASE_URL=postgresql+asyncpg://obs:obs@localhost:5432/obs

# Redis
REDIS_URL=redis://localhost:6379/0

# Ingestion service
INGEST_URL=http://localhost:4000
INGEST_API_KEY=dev-key

# ── LLM Endpoints (recommended) ───────────────────────────────────────────────
# Comma-separated URLs. The SDK probes each URL and auto-detects the provider:
#   Ollama          → detected via GET /api/tags
#   vLLM / LiteLLM → detected via GET /v1/models
#   AWS Bedrock     → detected from URL pattern (amazonaws.com)
#   Private VPC     → probed automatically (Ollama-compat first, then OpenAI-compat)
#
# Authenticated private endpoint: append |api_key after the URL
#   http://private-llm:8080|my-secret-key
#
# Examples:
#   LLM_ENDPOINTS=http://localhost:11434
#   LLM_ENDPOINTS=http://host.docker.internal:11434,http://private-vpc:8080
#   LLM_ENDPOINTS=https://bedrock-runtime.us-east-1.amazonaws.com
LLM_ENDPOINTS=

# ── Legacy keys (still supported if LLM_ENDPOINTS is not set) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=

# App settings
ENVIRONMENT=dev
PORT_INGESTION=4000
PORT_WEB=3000
STORE_RAW_MESSAGES=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
