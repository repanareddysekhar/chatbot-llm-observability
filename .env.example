# Database
DATABASE_URL=postgresql+asyncpg://obs:obs@localhost:5432/obs

# Redis
REDIS_URL=redis://localhost:6379/0

# Ingestion service
INGEST_URL=http://localhost:4000
INGEST_API_KEY=dev-key

# ── LLM Endpoints (recommended) ───────────────────────────────────────────────
# Comma-separated. ANY HTTP(S) URL works — ngrok, private VPC IP, localhost, etc.
# If probing fails, the endpoint is still registered as OpenAI-compatible.
#
#   http://10.0.1.5:8080
#   https://abc123.ngrok.io|my-api-key
#   my-vpc=http://10.0.1.5:8080|my-api-key              # alias shown in UI dropdown
#   openai_compatible://http://10.0.1.5:8080
#   ollama://http://localhost:11434
#   bedrock://us-east-1
#   LLM_DEFAULT_MODEL=my-model-name                      # used when probe finds no models
#   LLM_PROBE_TIMEOUT=5                                  # seconds (default 5)
#
LLM_ENDPOINTS=

# ── AWS Bedrock (legacy — used when LLM_ENDPOINTS is not set) ─────────────────
BEDROCK_ENABLED=
BEDROCK_RUNTIME_URL=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=

# ── Legacy keys (still supported if LLM_ENDPOINTS is not set) ─────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=

# App settings
ENVIRONMENT=dev
PORT_INGESTION=4000
PORT_WEB=3000
STORE_RAW_MESSAGES=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
