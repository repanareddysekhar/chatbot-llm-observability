# Database
DATABASE_URL=postgresql+asyncpg://obs:obs@localhost:5432/obs

# Redis
REDIS_URL=redis://localhost:6379/0

# Ingestion service
INGEST_URL=http://localhost:4000
INGEST_API_KEY=dev-key

# LLM provider keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama local models (no API key needed — just set the URL)
# Local dev: http://localhost:11434
# Inside Docker Compose: http://host.docker.internal:11434
OLLAMA_BASE_URL=

# App settings
ENVIRONMENT=dev
PORT_INGESTION=4000
PORT_WEB=3000
STORE_RAW_MESSAGES=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
